{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "<%= description %>",
  "author": "<%= author %>",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"<% if (!skipTesting) { %> \"test/**/*.ts\"<% } %>",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "oxlint src/<% if (!skipTesting) { %> test/<% } %>"<% if (!skipTesting) { %>,
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts"<% } %>
  },
  "dependencies": {
    "@nestjs/common": "next",
    "@nestjs/core": "next",
    "@nestjs/platform-express": "next",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "next",
    "@nestjs/schematics": "next"<% if (!skipTesting) { %>,
    "@nestjs/testing": "next"<% } %>,
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0"<% if (!skipTesting) { %>,
    "@types/supertest": "^7.0.0"<% } %>,
    "oxlint": "^1.58.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21"<% if (!skipTesting) { %>,
    "supertest": "^7.0.0"<% } %>,
    "typescript": "^6.0.2"<% if (!skipTesting) { %>,
    "vitest": "^4.1.2"<% } %>
  }
}
