{
  "name": "<%= name %>",
  "version": "<%= version %>",
  "description": "<%= description %>",
  "author": "<%= author %>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"<% if (!skipTesting) { %> \"test/**/*.ts\"<% } %>",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "oxlint src/<% if (!skipTesting) { %> test/<% } %>"<% if (!skipTesting) { %>,
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"<% } %>
  },
  "dependencies": {
    "@nestjs/common": "next",
    "@nestjs/core": "next",
    "@nestjs/platform-express": "next",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "next",
    "@nestjs/schematics": "next"<% if (!skipTesting) { %>,
    "@nestjs/testing": "next",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.0.0"<% } %>,
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0"<% if (!skipTesting) { %>,
    "jest": "^30.0.0"<% } %>,
    "oxlint": "^1.58.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21"<% if (!skipTesting) { %>,
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5"<% } %>,
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
